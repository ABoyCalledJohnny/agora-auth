# ===================================================================
# Dependencies
# Reinstalled by the package manager — never commit.
# ===================================================================
node_modules/
vendor/
bower_components/

# ===================================================================
# Build Artifacts
# Generated from source — don't version-control.
# ===================================================================
.next/
dist/
build/
public/build/
.output/
coverage/
*.d.ts

# ===================================================================
# Environment Secrets
# .env and .env.[environment] are committed (non-secret config).
# Only local secret overrides are ignored.
# ===================================================================
.env.local
.env.*.local
.env.tunnel

# ===================================================================
# Docker
# compose.override.yaml is personal dev config (gitignored).
# (.dockerignore also excludes compose files, Dockerfile, .git, etc.
#  — things Git tracks but Docker doesn't need in the build context.)
# ===================================================================
compose.override.yaml

# ===================================================================
# Logs
# ===================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-crash.txt

# ===================================================================
# OS & IDE
# ===================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ===================================================================
# User Content & Temporary Files
# Ignore uploaded files but keep the directory structure.
# (.dockerignore excludes uploads/ entirely — the Dockerfile creates
#  the directory itself. Runtime data is not a build input.)
# ===================================================================
uploads/*
!uploads/.gitkeep
tmp/
