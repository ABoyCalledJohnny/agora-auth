{
  "name": "agora-auth",
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11",
  "browserslist": [
    "last 2 versions",
    "> 0.5%",
    "not dead"
  ],
  "scripts": {
    "update:deps": "bunx npm-check-updates --target minor -u",
    "dev": "bun run docker:up && next dev --turbopack",
    "build": "next build",
    "lint": "eslint --fix",
    "lint:check": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "verify": "bun run lint && bun run typecheck && bun run format:check",
    "verify:build": "bun run lint && bun run typecheck && bun run format:check && bun run build",
    "db:studio": "bun --env-file=.env --env-file=.env.development --env-file=.env.local drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=.env --env-file=.env.development --env-file=.env.local drizzle-kit migrate",
    "db:push": "bun --env-file=.env --env-file=.env.development --env-file=.env.local drizzle-kit push",
    "db:bootstrap": "bun src/db/bootstrap.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:reset": "bun run docker:stop -- -v && bun run docker:up -- --wait && bun run db:push && bun run db:bootstrap && bun run db:seed",
    "docker:up": "sudo docker compose --env-file .env --env-file .env.development up -d",
    "docker:up:rebuild": "sudo docker compose --env-file .env --env-file .env.development up -d --build",
    "docker:full:up": "sudo docker compose --env-file .env --env-file .env.development --profile docker up -d",
    "docker:stop": "sudo docker compose --env-file .env --env-file .env.development --profile docker down",
    "docker:app:shell": "sudo docker compose exec app /bin/sh",
    "docker:db:shell": "sudo docker compose --env-file .env --env-file .env.development exec postgres sh -lc 'psql -U \"$POSTGRES_USER\" -d \"$POSTGRES_DB\"'",
    "release": "release-it",
    "release:rc": "release-it --preRelease=rc",
    "cleanup": "rm -rf .next node_modules",
    "reinstall": "bun run cleanup && bun install",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,md,yaml,yml}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "altcha": "^2.3.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "file-type": "^21.3.4",
    "jose": "^6.2.2",
    "mime-types": "^3.0.2",
    "nanoid": "^5.1.7",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "nodemailer": "^8.0.3",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "0.3.1",
    "eslint": "9",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "release-it": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "5"
  }
}
