# =============================================================================
# Base Environment Variables — shared defaults for ALL environments.
#
# These are non-secret values that rarely change between environments.
# Environment-specific files (.env.development, .env.production, etc.)
# override these where needed. Later files win.
#
# Loading order (Next.js):  .env → .env.[environment] → .env.local
# Loading order (Compose):  env_file entries, top to bottom (last wins)
# =============================================================================

# --- NETWORKING ---
# "0.0.0.0" binds to all interfaces (required for Docker and VPS).
# Override to "localhost" in .env.local for native macOS/Linux dev if needed.
HOSTNAME="0.0.0.0"
PORT="3000"

# --- DATABASE ---
# Default DB port exposed by Docker (can be overridden per-env)
DB_HOST = "localhost"
DB_PORT="5432"

# --- FEATURE FLAGS ---
NEXT_PUBLIC_ENABLE_REGISTRATION="true"

# --- LOGGING ---
# Levels: debug, info, warn, error
LOG_LEVEL="info"