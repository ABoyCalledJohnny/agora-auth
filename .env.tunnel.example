# =============================================================================
# SSH Tunnel Variables - copy to .env.tunnel and fill in REAL PRODUCTION values.
#
# .env.tunnel MUST BE gitignored.
# Used strictly for connecting Drizzle Studio locally to the production database over SSH.
# Run via: bun run db:studio:prod
# =============================================================================

POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB=""

# The local port your SSH tunnel is bound to (e.g. ssh -L 5432:127.0.0.1:5432)
DB_PORT="5432"
DB_HOST="localhost"