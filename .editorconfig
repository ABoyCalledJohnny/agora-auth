# http://editorconfig.org
root = true

# All files
[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files (allow trailing whitespace for line breaks)
[*.md]
trim_trailing_whitespace = false

# Shell scripts (Tabs are safer for some systems)
[*.sh]
end_of_line = lf
indent_style = tab
indent_size = 4
