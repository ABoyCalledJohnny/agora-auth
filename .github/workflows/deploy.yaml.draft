# =============================================================================
# REFERENCE: Removed Production Commands (for manual VPS usage)
# =============================================================================
# Run these directly on your VPS when needed (assuming you are in the project root):
# 
# Drizzle Studio (Production):
#   npx drizzle-kit studio
#
# Drizzle Migrate (Production):
#   npx drizzle-kit migrate
#
# Drizzle Push (Production):
#   npx drizzle-kit push
#
# Docker Postgres Shell (Production):
#   sudo docker compose -f compose.yaml -f compose.production.yaml exec postgres sh -lc 'psql -U "$POSTGRES_USER" -d "$POSTGRES_DB"'