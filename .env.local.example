# =============================================================================
# Local Secrets — copy to .env.local and fill in real values.
#
# .env.local is gitignored — never commit it.
# Next.js loads it last, so values here override everything.
# =============================================================================

# --- SMTP (e.g. Mailtrap sandbox for local email testing) ---
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER="dummy_username"
SMTP_PASSWORD="dummy_password"

# --- App DB User (required for config validation during `next build`) ---
APP_DB_USER="agora_auth_dev_app_user"
APP_DB_PASSWORD="agora_auth_dev_app_password"
AUTH_SECRET="local_dummy_auth_secret_for_jwt_signing_123"
INITIAL_ADMIN_EMAIL="admin@localhost.com" # Put a real email address here to test email flows in dev
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="local_dummy_admin_password"
DEFAULT_CLIENT_ID="crtrvewglftwpvvwcxpdecaixti"
DEFAULT_CLIENT_SECRET="local_dummy_client_secret"

# --- JWT Asymmetric Keys (RS256) ---
# Generate a dev-only key pair:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste the PEM contents (use double quotes).
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""